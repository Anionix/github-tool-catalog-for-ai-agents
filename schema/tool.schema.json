{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Anionix/github-tool-catalog-for-ai-agents/schema/tool.schema.json",
  "title": "GitHub Tool Catalog for AI Agents",
  "type": "object",
  "required": ["schema_version", "categories", "tools"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/tool"
      }
    }
  },
  "$defs": {
    "level": {
      "type": "string",
      "enum": ["high", "medium", "low", "watch"]
    },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "status": {
      "type": "string",
      "enum": ["recommended", "situational", "watch", "avoid"]
    },
    "kind": {
      "type": "string",
      "enum": ["mcp", "connector", "cli", "gh-extension", "agent-workflow", "agent-cli", "lsp-mcp", "git-tui", "git-pager", "repo-manager"]
    },
    "tool": {
      "type": "object",
      "required": [
        "name",
        "repo",
        "url",
        "kind",
        "category",
        "summary",
        "agent_usefulness",
        "human_usefulness",
        "risk",
        "recommended_status",
        "install"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://github.com/"
        },
        "kind": {
          "$ref": "#/$defs/kind"
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 20
        },
        "agent_usefulness": {
          "$ref": "#/$defs/level"
        },
        "human_usefulness": {
          "$ref": "#/$defs/level"
        },
        "risk": {
          "$ref": "#/$defs/risk"
        },
        "recommended_status": {
          "$ref": "#/$defs/status"
        },
        "install": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
